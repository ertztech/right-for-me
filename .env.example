# Copy this file to .env and fill in your real Trello credentials.
# Do not commit .env.

TRELLO_API_KEY=
TRELLO_TOKEN=

# Optional. If set, board_builder.py will update this board instead of creating a new one.
TRELLO_BOARD_ID=

# OpenAI live AI integration. Do not commit real keys.
OPENAI_API_KEY=your_openai_api_key_here

# Optional. Defaults to GPT-5.5 if not set.
OPENAI_MODEL=gpt-5.5

# Optional local development mode. When true, Review Opportunity uses deterministic mock AI.
VITE_AI_TEST_MODE=false
